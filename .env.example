# rell-scratch — environment variables template
#
# Copy this file to `.env.local` at the monolith root (for web) and to
# `.env` inside the mobile workspace, then fill in the values before
# running the app. Never commit real credentials — the generated
# .gitignore already excludes `.env*` (except this example file).

# =============================================================================
# WEB (Next.js — .env.local at the monolith root)
# =============================================================================

# Clerk — get these from https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Billing webhook signing secret — required by the webhook route
# added in Story 3.2. Configure the webhook in your Clerk Dashboard at
# https://dashboard.clerk.com/last-active?path=webhooks and paste the
# Signing Secret here so the app can verify incoming events.
CLERK_BILLING_WEBHOOK_SIGNING_SECRET=

# Supabase — get these from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Drizzle / direct Postgres connection — populated fully in Story 2.4
# DATABASE_URL=postgresql://postgres:[password]@[project-ref].supabase.co:5432/postgres

# Public support phone shown across the marketing site (display format).
# When UNSET, the site renders no phone number at all (no placeholder) — set
# the real dispatch line before launch.
NEXT_PUBLIC_SUPPORT_PHONE=

# Resend — waitlist confirmation email (optional; no-ops if unset).
# https://resend.com → API Keys, and verify your sending domain.
RESEND_API_KEY=
WAITLIST_FROM_EMAIL=

# Stripe webhook signing secret. REQUIRED for the payment webhook to accept
# events — the route fails closed (503) without it and rejects any request
# whose signature does not verify. From https://dashboard.stripe.com → Webhooks.
STRIPE_WEBHOOK_SECRET=

# Shared secret for machine-triggered cron endpoints (e.g. ride reminders).
# The scheduler must send `Authorization: Bearer <CRON_SECRET>`. Endpoints
# fail closed (503) when this is unset. Generate a long random value.
CRON_SECRET=

# =============================================================================
# MOBILE (Expo — .env inside the mobile/ workspace)
# =============================================================================
# Expo only exposes vars prefixed with EXPO_PUBLIC_ to the compiled bundle.
# Do NOT put secrets here — they will be extractable from the shipped app.

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Live legal-document URLs shown in the mobile app's legal screens. Point these
# at the published web pages (e.g. https://www.vf1st.com/privacy and /terms).
# App Store / Play submission requires a working privacy-policy URL.
EXPO_PUBLIC_PRIVACY_POLICY_URL=
EXPO_PUBLIC_TERMS_URL=

# =============================================================================
# ENVIRONMENT MARKER (web + mobile)
# =============================================================================
# Which environment this build/runtime targets: production | staging | development.
# Backends are shared across environments today; this drives env-aware behavior
# (banners, analytics, prod guardrails) and is the seam for a future per-env
# backend split. Web reads NEXT_PUBLIC_APP_ENV (set per Vercel environment);
# mobile reads EXPO_PUBLIC_APP_ENV (set per EAS build profile in eas.json).
NEXT_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_ENV=development
