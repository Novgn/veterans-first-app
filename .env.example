# =============================================================================
# Veterans First App - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database Connection (Drizzle ORM)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]

# App connections: Use Transaction pooler (port 6543) for serverless/edge
# This is used by the app at runtime for queries
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Migrations: Use Direct connection (port 5432) - REQUIRED for db:generate and db:push
# Transaction pooler doesn't support prepared statements needed for DDL operations
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Get these from your Clerk Dashboard: https://dashboard.clerk.com
# Navigate to: Settings > API Keys

# Publishable Key (safe for client-side use)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Secret Key (server-side only - NEVER expose to client)
CLERK_SECRET_KEY=sk_test_xxx

# Clerk Webhook Secret (for Supabase Edge Function user sync)
# Get this from: Clerk Dashboard > Webhooks > Your Webhook > Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxx

# Clerk Domain (for Supabase third-party auth)
# Format: your-app-name.clerk.accounts.dev
CLERK_DOMAIN=

# Custom Clerk URLs (optional - uncomment if using custom routing)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Stripe Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Twilio SMS
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
