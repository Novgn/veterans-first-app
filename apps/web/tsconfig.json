{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Web needs DOM libs; the shared base tsconfig intentionally omits them
    // so the mobile workspace isn't polluted with browser types.
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    },
    "incremental": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
