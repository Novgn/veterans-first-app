{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start": "expo start",
    "dev": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "typecheck": "tsc --noEmit",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@clerk/clerk-expo": "2.19.31",
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.6",
    "@supabase/supabase-js": "2.87.0",
    "@tanstack/query-async-storage-persister": "5.90.14",
    "@tanstack/react-query": "5.90.12",
    "@tanstack/react-query-persist-client": "5.90.14",
    "@veterans-first/shared": "*",
    "date-fns": "3.6.0",
    "expo": "55.0.15",
    "expo-dev-client": "~55.0.27",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-location": "~55.1.8",
    "expo-router": "~55.0.12",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.15",
    "expo-web-browser": "~55.0.14",
    "nativewind": "4.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-google-places-autocomplete": "2.6.1",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "zustand": "5.0.9"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.2.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-test-renderer": "19.2.5",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": [
      "./jest.setup-before.js"
    ],
    "setupFilesAfterEnv": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|nativewind|@clerk/clerk-expo|zustand)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^expo-modules-core$": "<rootDir>/__mocks__/expo-modules-core.js",
      "^expo-modules-core/(.*)$": "<rootDir>/__mocks__/expo-modules-core.js",
      "^react$": "<rootDir>/../../node_modules/react",
      "^react/(.*)$": "<rootDir>/../../node_modules/react/$1"
    },
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "private": true
}
